{
  "name": "salesforce-agent-optimizer-tool-registry",
  "version": "2.1.0",
  "principles": [
    "Ask for an explicit org alias before org operations.",
    "Treat production orgs as read-only.",
    "Prefer read, preview, validate, and manifest operations before write operations.",
    "Require separate explicit approval for destructive operations.",
    "Require separate explicit approval before exposing Salesforce secrets.",
    "Return compact JSON and select only fields needed for planning."
  ],
  "toolsets": {
    "core": ["auth-web", "auth-device", "auth-jwt", "org-list", "org-inspect", "org-limits"],
    "schema": ["schema-sobject-list", "schema-sobject-describe", "data-query"],
    "data-read": ["data-query", "data-record-get"],
    "metadata": ["metadata-list", "metadata-retrieve", "metadata-retrieve-manifest"],
    "deploy": ["deploy-preview", "deploy-validate", "deploy-start", "deploy-report"],
    "permissions": ["access-inspect", "user-display", "permset-assign"],
    "apex": ["apex-test-run", "apex-test-report", "apex-log-list", "apex-log-get", "apex-run"],
    "packages": ["package-installed-list", "package-install", "package-uninstall"],
    "local": ["local-manifest-generate", "catalog-refresh"]
  },
  "tools": [
    {
      "name": "auth-web",
      "category": "core",
      "safety": "auth",
      "requires_alias": false,
      "production": "auth-only",
      "maps_to": "sf org login web",
      "description": "Interactive OAuth login with browser protection.",
      "arguments": {"alias": "required", "instance_url": "optional"},
      "output": {"recommended_select": "result.alias,result.username,result.orgId"},
      "example": {"options": {"alias": "dev"}}
    },
    {
      "name": "auth-device",
      "category": "core",
      "safety": "auth",
      "requires_alias": false,
      "production": "auth-only",
      "maps_to": "sf org login device",
      "description": "Device-code OAuth login when browser login is not practical.",
      "arguments": {"alias": "required", "instance_url": "optional"},
      "output": {"recommended_select": "result.alias,result.username,result.orgId"},
      "example": {"options": {"alias": "dev"}}
    },
    {
      "name": "auth-jwt",
      "category": "core",
      "safety": "auth",
      "requires_alias": false,
      "production": "auth-only",
      "maps_to": "sf org login jwt",
      "description": "JWT bearer login for CI with connected app and private key.",
      "arguments": {"alias": "required", "username": "required", "client_id": "required", "jwt_key_file": "required"},
      "output": {"recommended_select": "result.alias,result.username,result.orgId"},
      "example": {"options": {"alias": "ci", "username": "user@example.com", "client_id": "CONNECTED_APP_ID", "jwt_key_file": "server.key"}}
    },
    {
      "name": "org-list",
      "category": "core",
      "safety": "read",
      "requires_alias": false,
      "production": "read-only",
      "maps_to": "sf org list",
      "description": "List locally authenticated orgs without relying on default org behavior.",
      "arguments": {},
      "output": {"recommended_select": "result.nonScratchOrgs,result.scratchOrgs"},
      "example": {"options": {}}
    },
    {
      "name": "org-inspect",
      "category": "core",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf org display + SOQL Organization",
      "description": "Inspect org identity and sandbox/production status before planning writes.",
      "arguments": {"target_org": "required"},
      "output": {"recommended_select": "org_display.alias,org_display.username,organization.records.0.IsSandbox,organization.records.0.OrganizationType"},
      "example": {"options": {}}
    },
    {
      "name": "org-limits",
      "category": "core",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf limits api display",
      "description": "Read API and org limits for capacity-aware planning.",
      "arguments": {"target_org": "required"},
      "output": {"recommended_select": "result"},
      "example": {"options": {}}
    },
    {
      "name": "schema-sobject-list",
      "category": "schema",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf sobject list",
      "description": "List available sObjects by category.",
      "arguments": {"target_org": "required", "sobject_type": "optional"},
      "output": {"recommended_select": "result"},
      "example": {"options": {"sobject_type": "custom"}}
    },
    {
      "name": "schema-sobject-describe",
      "category": "schema",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf sobject describe",
      "description": "Describe one sObject for field, relationship, create/update and picklist planning.",
      "arguments": {"target_org": "required", "sobject": "required"},
      "output": {"recommended_select": "result.name,result.fields,result.childRelationships"},
      "example": {"options": {"sobject": "Account"}}
    },
    {
      "name": "metadata-list",
      "category": "metadata",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf org list metadata",
      "description": "List metadata members for a metadata type.",
      "arguments": {"target_org": "required", "metadata_type": "required", "folder": "optional"},
      "output": {"recommended_select": "result"},
      "example": {"options": {"metadata_type": "CustomObject"}}
    },
    {
      "name": "metadata-retrieve",
      "category": "metadata",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf project retrieve start --metadata",
      "description": "Retrieve named metadata selectors into the local project.",
      "arguments": {"target_org": "required", "metadata": "required-repeatable"},
      "output": {"recommended_select": "result.status,result.files"},
      "example": {"options": {"metadata": ["ApexClass:AccountService"]}}
    },
    {
      "name": "metadata-retrieve-manifest",
      "category": "metadata",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf project retrieve start --manifest",
      "description": "Retrieve metadata from a package.xml manifest.",
      "arguments": {"target_org": "required", "manifest": "required"},
      "output": {"recommended_select": "result.status,result.files"},
      "example": {"options": {"manifest": "manifest/package.xml"}}
    },
    {
      "name": "deploy-preview",
      "category": "deploy",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf project deploy preview",
      "description": "Preview deploy contents without changing the org.",
      "arguments": {"target_org": "required", "source_dir_or_manifest": "required"},
      "output": {"recommended_select": "result"},
      "example": {"options": {"source_dir": ["force-app"]}}
    },
    {
      "name": "deploy-validate",
      "category": "deploy",
      "safety": "execute",
      "requires_alias": true,
      "production": "blocked",
      "maps_to": "sf project deploy validate",
      "description": "Validate a deployment without committing metadata. Blocked on production by policy.",
      "arguments": {"target_org": "required", "source_dir_or_manifest": "required", "test_level": "optional", "tests": "optional-repeatable"},
      "output": {"recommended_select": "result.id,result.status,result.success,result.details"},
      "example": {"options": {"source_dir": ["force-app"], "test_level": "RunLocalTests"}}
    },
    {
      "name": "deploy-start",
      "category": "deploy",
      "safety": "write",
      "requires_alias": true,
      "production": "blocked",
      "maps_to": "sf project deploy start",
      "description": "Deploy source metadata. Requires requirements and changed metadata for Knowledge history.",
      "arguments": {"target_org": "required", "source_dir_or_manifest": "required", "requirements": "required", "changed_metadata": "required-repeatable"},
      "output": {"recommended_select": "result.id,result.status,result.success,result.files"},
      "example": {"options": {"source_dir": ["force-app"], "requirements": "Approved requirement", "changed_metadata": ["ApexClass:AccountService"]}}
    },
    {
      "name": "deploy-report",
      "category": "deploy",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf project deploy report",
      "description": "Read deployment status by job id.",
      "arguments": {"target_org": "required", "job_id": "required"},
      "output": {"recommended_select": "result.id,result.status,result.success,result.details"},
      "example": {"options": {"job_id": "0Af..."}}
    },
    {
      "name": "data-query",
      "category": "data-read",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf data query",
      "description": "Run focused SOQL with explicit fields and compact JSON output.",
      "arguments": {"target_org": "required", "query": "required", "tooling": "optional"},
      "output": {"recommended_select": "result.totalSize,result.records"},
      "example": {"options": {"query": "SELECT Id, Name FROM Account LIMIT 10"}}
    },
    {
      "name": "data-record-get",
      "category": "data-read",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf data get record",
      "description": "Read one record by sObject and record id.",
      "arguments": {"target_org": "required", "sobject": "required", "record_id": "required"},
      "output": {"recommended_select": "result.fields"},
      "example": {"options": {"sobject": "Account", "record_id": "001..."}}
    },
    {
      "name": "data-record-create",
      "category": "data-write",
      "safety": "write",
      "requires_alias": true,
      "production": "blocked",
      "maps_to": "sf data create record",
      "description": "Create one record. Blocked on production by policy.",
      "arguments": {"target_org": "required", "sobject": "required", "values": "required"},
      "output": {"recommended_select": "result.id,result.success"},
      "example": {"options": {"sobject": "Account", "values": "Name=Example"}}
    },
    {
      "name": "data-record-update",
      "category": "data-write",
      "safety": "write",
      "requires_alias": true,
      "production": "blocked",
      "maps_to": "sf data update record",
      "description": "Update one record. Blocked on production by policy.",
      "arguments": {"target_org": "required", "sobject": "required", "record_id": "required", "values": "required"},
      "output": {"recommended_select": "result.id,result.success"},
      "example": {"options": {"sobject": "Account", "record_id": "001...", "values": "Rating=Hot"}}
    },
    {
      "name": "data-record-delete",
      "category": "data-write",
      "safety": "destructive",
      "requires_alias": true,
      "production": "blocked",
      "maps_to": "sf data delete record",
      "description": "Delete one record. Requires separate explicit deletion approval.",
      "arguments": {"target_org": "required", "sobject": "required", "record_id": "required", "delete_approval": "required-exact"},
      "output": {"recommended_select": "result.id,result.success"},
      "example": {"options": {"sobject": "Account", "record_id": "001...", "delete_approval": "I explicitly approve this deletion"}}
    },
    {
      "name": "access-inspect",
      "category": "permissions",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "SOQL User + PermissionSetAssignment + PermissionSetGroup + ObjectPermissions + FieldPermissions",
      "description": "Inspect user access for least-privilege planning and permission analyzer v2.",
      "arguments": {"target_org": "required", "username_or_user_id_or_where": "required", "sobject": "optional-repeatable"},
      "output": {"recommended_select": "least_privilege_note,users.records,permission_set_assignments.records,permission_set_groups.records,object_permissions.records,field_permissions.records,access_explanations"},
      "example": {"options": {"username": ["user@example.com"], "sobject": ["Account"]}}
    },
    {
      "name": "apex-test-run",
      "category": "apex",
      "safety": "execute",
      "requires_alias": true,
      "production": "blocked",
      "maps_to": "sf apex run test",
      "description": "Run Apex tests with optional coverage. Blocked on production by policy.",
      "arguments": {"target_org": "required", "tests_or_suite_names": "required", "code_coverage": "optional"},
      "output": {"recommended_select": "result.summary,result.tests,result.codecoverage"},
      "example": {"options": {"tests": ["AccountServiceTest"], "code_coverage": true}}
    },
    {
      "name": "apex-test-report",
      "category": "apex",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf apex get test",
      "description": "Read an Apex test run report.",
      "arguments": {"target_org": "required", "test_run_id": "required"},
      "output": {"recommended_select": "result.summary,result.tests,result.codecoverage"},
      "example": {"options": {"test_run_id": "707..."}}
    },
    {
      "name": "apex-log-list",
      "category": "apex",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf apex list log",
      "description": "List Apex debug logs.",
      "arguments": {"target_org": "required"},
      "output": {"recommended_select": "result"},
      "example": {"options": {}}
    },
    {
      "name": "apex-log-get",
      "category": "apex",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf apex get log",
      "description": "Fetch one Apex debug log.",
      "arguments": {"target_org": "required", "log_id": "required"},
      "output": {"recommended_select": "result"},
      "example": {"options": {"log_id": "07L..."}}
    },
    {
      "name": "apex-run",
      "category": "apex",
      "safety": "execute",
      "requires_alias": true,
      "production": "blocked",
      "maps_to": "sf apex run",
      "description": "Execute anonymous Apex from a local file. Blocked on production by policy.",
      "arguments": {"target_org": "required", "file": "required"},
      "output": {"recommended_select": "result.compiled,result.success,result.logs"},
      "example": {"options": {"file": "scripts/anonymous.apex"}}
    },
    {
      "name": "package-installed-list",
      "category": "packages",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf package installed list",
      "description": "List installed packages.",
      "arguments": {"target_org": "required"},
      "output": {"recommended_select": "result"},
      "example": {"options": {}}
    },
    {
      "name": "package-install",
      "category": "packages",
      "safety": "write",
      "requires_alias": true,
      "production": "blocked",
      "maps_to": "sf package install",
      "description": "Install a package. Blocked on production by policy.",
      "arguments": {"target_org": "required", "package": "required", "wait": "optional"},
      "output": {"recommended_select": "result.Id,result.Status,result.SubscriberPackageVersionId"},
      "example": {"options": {"package": "04t...", "wait": 30}}
    },
    {
      "name": "package-uninstall",
      "category": "packages",
      "safety": "destructive",
      "requires_alias": true,
      "production": "blocked",
      "maps_to": "sf package uninstall",
      "description": "Uninstall a package. Requires separate explicit deletion approval.",
      "arguments": {"target_org": "required", "package": "required", "delete_approval": "required-exact"},
      "output": {"recommended_select": "result.Id,result.Status"},
      "example": {"options": {"package": "04t...", "delete_approval": "I explicitly approve this deletion"}}
    },
    {
      "name": "user-display",
      "category": "permissions",
      "safety": "read",
      "requires_alias": true,
      "production": "read-only",
      "maps_to": "sf org display user",
      "description": "Display user information for an org or target user.",
      "arguments": {"target_org": "required", "target_user": "optional"},
      "output": {"recommended_select": "result.username,result.profileName,result.userId,result.orgId"},
      "example": {"options": {"target_user": "user@example.com"}}
    },
    {
      "name": "permset-assign",
      "category": "permissions",
      "safety": "write",
      "requires_alias": true,
      "production": "blocked",
      "maps_to": "sf org assign permset",
      "description": "Assign a permission set only after least-privilege planning approval.",
      "arguments": {"target_org": "required", "name": "required", "on_behalf_of": "optional"},
      "output": {"recommended_select": "result.successes,result.failures"},
      "example": {"options": {"name": "Invoice_User", "on_behalf_of": "user@example.com"}}
    },
    {
      "name": "local-manifest-generate",
      "category": "local",
      "safety": "local",
      "requires_alias": false,
      "production": "local-only",
      "maps_to": "sf project generate manifest",
      "description": "Generate a local package.xml manifest from source or metadata selectors.",
      "arguments": {"metadata": "optional-repeatable", "source_dir": "optional-repeatable", "output_dir": "optional"},
      "output": {"recommended_select": "result"},
      "example": {"options": {"metadata": ["ApexClass:AccountService"], "output_dir": "manifest"}}
    },
    {
      "name": "safe-run",
      "category": "dynamic",
      "safety": "dynamic",
      "requires_alias": false,
      "production": "policy-classified",
      "maps_to": "sf <official-command>",
      "description": "Run an official sf command with alias enforcement, production guardrails, secret-exposure guardrails and compact output.",
      "arguments": {"sf_args": "required", "target_org": "required-when-org-command", "safety": "optional", "delete_approval": "required-for-destructive", "secret_approval": "required-for-secret-exposure"},
      "output": {"recommended_select": "result"},
      "example": {"options": {"sf_args": ["data", "query", "--query", "SELECT Id FROM Account LIMIT 1"]}}
    },
    {
      "name": "catalog-refresh",
      "category": "local",
      "safety": "local",
      "requires_alias": false,
      "production": "local-only",
      "maps_to": "sf commands --json",
      "description": "Generate compact local documentation for installed official sf commands.",
      "arguments": {"output_dir": "optional"},
      "output": {"recommended_select": "catalog_path,command_count"},
      "example": {"options": {"output_dir": "references"}}
    }
  ]
}
